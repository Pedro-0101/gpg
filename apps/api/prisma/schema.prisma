generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  dailyHours  Int       @default(8)
  status      String    @default("active")
  totalBudget Decimal?  @db.Decimal(12, 2)
  client      String?
  managerId   String?   // professionalId do PM
  color       String    @default("#4F46E5")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  stages        Stage[]
  teams         Team[]
  stakeholders  Stakeholder[]
  professionals Professional[]
  costs         CostEntry[]
  risks         Risk[]
  milestones    Milestone[]
  decisions     Decision[]
}

model Stage {
  id        String    @id @default(cuid())
  projectId String
  name      String
  order     Int
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  topics     Topic[]
  costs      CostEntry[]
  milestones Milestone[]

  @@unique([projectId, order])
}

model Topic {
  id        String    @id @default(cuid())
  stageId   String
  name      String
  order     Int
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  stage     Stage      @relation(fields: [stageId], references: [id], onDelete: Cascade)
  subtopics Subtopic[]

  @@unique([stageId, order])
}

model Subtopic {
  id            String    @id @default(cuid())
  topicId       String
  name          String
  description   String?
  durationHours Int
  isConcurrent  Boolean   @default(false)
  order         Int       @default(1)
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("todo")
  progress      Int       @default(0)
  spentHours    Float     @default(0)
  deadline      DateTime?
  taskType      String    @default("task")
  priority      String    @default("med")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  topic       Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  teams       SubtopicTeam[]
  comments    SubtopicComment[]
  attachments SubtopicAttachment[]
}

model SubtopicTeam {
  subtopicId String
  teamId     String

  subtopic Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@id([subtopicId, teamId])
}

// Profissional = pessoa real nomeada com função e custo/hora
model Professional {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  initials    String   @db.VarChar(4)
  role        String
  hourlyCost  Decimal  @db.Decimal(10, 2)
  skills      String[] @default([])
  avatarColor Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  teams     TeamProfessional[]
  costs     CostEntry[]
  decisions Decision[]
}

model Team {
  id        String   @id @default(cuid())
  projectId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  professionals TeamProfessional[]
  subtopics     SubtopicTeam[]
}

model TeamProfessional {
  teamId         String
  professionalId String

  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@id([teamId, professionalId])
}

model Stakeholder {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  role            String?
  organization    String?
  type            String   @default("external")
  influence       Int      @default(3)
  interest        Int      @default(3)
  engagementLevel String   @default("neutral")
  contactInfo     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CostEntry {
  id             String   @id @default(cuid())
  projectId      String
  stageId        String?
  professionalId String?
  description    String
  category       String
  amount         Decimal  @db.Decimal(10, 2)
  hours          Float?
  date           DateTime @default(now())
  createdAt      DateTime @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage        Stage?        @relation(fields: [stageId], references: [id])
  professional Professional? @relation(fields: [professionalId], references: [id])
}

model Risk {
  id           String    @id @default(cuid())
  projectId    String
  title        String
  description  String?
  probability  String    @default("med")
  impact       String    @default("med")
  status       String    @default("active")
  responsePlan String?
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  stageId   String?
  name      String
  date      DateTime
  status    String   @default("pending")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage   Stage?  @relation(fields: [stageId], references: [id])
}

model Decision {
  id             String    @id @default(cuid())
  projectId      String
  professionalId String?
  title          String
  description    String?
  dueDate        DateTime?
  status         String    @default("pending")
  createdAt      DateTime  @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  professional Professional? @relation(fields: [professionalId], references: [id])
}

model SubtopicComment {
  id         String   @id @default(cuid())
  subtopicId String
  authorName String
  content    String
  createdAt  DateTime @default(now())

  subtopic Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
}

model SubtopicAttachment {
  id         String   @id @default(cuid())
  subtopicId String
  name       String
  size       Int
  url        String
  mimeType   String
  isExternal Boolean  @default(false)
  uploadedAt DateTime @default(now())

  subtopic Subtopic @relation(fields: [subtopicId], references: [id], onDelete: Cascade)
}
