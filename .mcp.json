{
  "mcpServers": {
    "gpg-local": {
      "command": "cmd",
      "args": ["/c", "pnpm", "--silent", "--filter", "@gpg/mcp", "start"],
      "env": {
        "API_URL": "http://localhost:3001/api/v1"
      }
    },
    "gpg-prod": {
      "command": "cmd",
      "args": ["/c", "pnpm", "--silent", "--filter", "@gpg/mcp", "start"],
      "env": {
        "API_URL": "https://gpgweb-production.up.railway.app/api/v1"
      }
    }
  }
}
